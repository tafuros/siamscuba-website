{
  "cleanUrls": true,
  "trailingSlash": false,
  "functions": {
    "api/chat.ts": { "includeFiles": "api/_kb.json" }
  },
  "redirects": [
    { "source": "/contact-us", "destination": "/", "permanent": true },
    { "source": "/zero-to-hero-dive-master-internship", "destination": "/divemaster", "permanent": true },
    { "source": "/nemo", "destination": "https://wa.me/66825068898?text=Hi%20Nemo!%20%F0%9F%90%A0", "permanent": false }
  ],
  "rewrites": [
    { "source": "/((?!api/).*)", "destination": "/index.html" }
  ],
  "headers": [
    {
      "source": "/api/info.json",
      "headers": [
        {
          "key": "Cache-Control",
          "value": "public, max-age=3600, s-maxage=3600, stale-while-revalidate=86400"
        },
        {
          "key": "Content-Type",
          "value": "application/json; charset=utf-8"
        },
        {
          "key": "Access-Control-Allow-Origin",
          "value": "*"
        }
      ]
    },
    {
      "source": "/hero/(.*)",
      "headers": [
        { "key": "Cache-Control", "value": "public, max-age=31536000, immutable" }
      ]
    }
  ]
}
